{
  "name": "@lerna-labs/hydra-sdk-monorepo",
  "description": "A collection of helpful code and examples for building applications leveraging Hydra technology",
  "private": true,
  "type": "module",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check packages/ examples/",
    "lint:fix": "biome check --write packages/ examples/",
    "typecheck": "tsc -p packages/core/tsconfig.build.json --noEmit && tsc -p packages/proof/tsconfig.build.json --noEmit",
    "start:api": "tsx watch examples/local-currency/index.ts",
    "build": "npm run build -ws",
    "build:sdk": "npm run build -w @lerna-labs/hydra-sdk",
    "build:proof": "npm run build -w @lerna-labs/hydra-proof"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lerna-labs/hydra-sdk.git"
  },
  "author": "Adam Dean <adam@crypto2099.io>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/lerna-labs/hydra-sdk/issues"
  },
  "homepage": "https://github.com/lerna-labs/hydra-sdk#readme",
  "workspaces": {
    "packages": [
      "packages/core",
      "packages/proof",
      "examples/local-currency"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/express": "^5.0.3",
    "@types/ws": "^8.18.1",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@emurgo/cardano-message-signing-nodejs": "^1.1.0",
    "@emurgo/cardano-serialization-lib-nodejs": "^15.0.3",
    "@meshsdk/core": "1.9.0-beta.99",
    "@meshsdk/core-csl": "1.9.0-beta.99",
    "@meshsdk/hydra": "1.9.0-beta.99",
    "@noble/hashes": "^2.0.1",
    "axios": "^1.11.0",
    "commander": "^14.0.1",
    "dotenv": "^17.2.1",
    "express": "^5.2.1",
    "tx3-sdk": "^0.7.0",
    "utf-8-validate": "^5.0.2",
    "ws": "^8.18.3"
  }
}
