# ──────────────────────────────────────────────────
# Preprod-Specific Environment Variables
# ──────────────────────────────────────────────────

# The transaction ID containing Hydra Reference Scripts on the network
HYDRA_TX_ID=c9c4d820d5575173cfa81ba2d2d1096fc40f84d16d8c17284da410a4fb5e64eb,ae4443b46f550289337fc5c2c52b24f1288dab36d1a229167a6e04f056a966fe,48bd29e43dd01d12ab464f75fe40eed80e4051c8d3409e1cb20b8c01120b425e

# The network magic of the cardano-node you will be connecting to:
# 1: Preprod
# 2: Preview
HYDRA_NETWORK_ID=1

# The directory that will hold the configuration files, keys, Cardano Node and Hydra persistence files
SCRIPTS_DIR=../scripts/preprod

USE_TLS=0

# The port that our Express API will be exposed on
EXPRESS_PORT=3002

# Your Blockfrost API key for the network you're connecting to
BLOCKFROST_API_KEY=preprod<your_api_key_here>

# The full URL for the Hydra HTTP API
HYDRA_API_URL=http://hydra-node:4002

# The full URL for the Hydra WS API
HYDRA_WS_URL=ws://hydra-node:4002

# The full URL for the Tx3 Hydra TRP
TRP_URL=http://hydra-trp:8166

HYDRA_NETWORK=0

# Add your network-specific admin credential after generating keys here
HYDRA_ADMIN_CARDANO_PK=5820...cf04

# The header value for x-api-key that Express Middleware will check for
X_API_KEY=DONT-DDOS-MY-SERVER-BRO

# The port that Cardano node will use
CARDANO_PORT=3003

# Participant identity (will be used as name for generated keys)
NODE_ID=preprod1

# The host used for hydra-node HTTP and WS API
API_HOST=0.0.0.0

# The port used for hydra-node HTTP and WS API
API_PORT=4002

# The host used by hydra-node to connect to peers
LISTEN_HOST=0.0.0.0

# The port used by hydra-node to connect to peers
LISTEN_PORT=5002

# The host used by Tx3 Hydra TRP
TRP_HOST=0.0.0.0

# The port used by Tx3 Hydra TRP
TRP_PORT=8166