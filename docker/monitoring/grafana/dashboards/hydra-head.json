{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Confirmed Transactions (rate/min)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "tx/min",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "rate(hydra_head_confirmed_tx[1m]) * 60",
          "legendFormat": "{{network}}/{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Transaction Confirmation Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "ms",
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(hydra_head_tx_confirmation_time_ms_bucket[5m]))",
          "legendFormat": "p50 {{network}}/{{instance}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(hydra_head_tx_confirmation_time_ms_bucket[5m]))",
          "legendFormat": "p95 {{network}}/{{instance}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(hydra_head_tx_confirmation_time_ms_bucket[5m]))",
          "legendFormat": "p99 {{network}}/{{instance}}",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Confirmed vs Requested Transactions",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "total",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "hydra_head_confirmed_tx",
          "legendFormat": "confirmed {{network}}/{{instance}}",
          "refId": "A"
        },
        {
          "expr": "hydra_head_requested_tx",
          "legendFormat": "requested {{network}}/{{instance}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Requested Transaction Rate (rate/min)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "tx/min",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "rate(hydra_head_requested_tx[1m]) * 60",
          "legendFormat": "{{network}}/{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "stacking": { "mode": "normal" },
            "spanNulls": false
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "avg without(cpu) (rate(node_cpu_seconds_total{mode=\"user\"}[5m]))",
          "legendFormat": "user",
          "refId": "A"
        },
        {
          "expr": "avg without(cpu) (rate(node_cpu_seconds_total{mode=\"system\"}[5m]))",
          "legendFormat": "system",
          "refId": "B"
        },
        {
          "expr": "avg without(cpu) (rate(node_cpu_seconds_total{mode=\"iowait\"}[5m]))",
          "legendFormat": "iowait",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Memory",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "node_memory_Cached_bytes + node_memory_Buffers_bytes",
          "legendFormat": "Cached + Buffers",
          "refId": "B"
        },
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "Available",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Disk IOPS",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "iops"
        }
      },
      "targets": [
        {
          "expr": "rate(node_disk_reads_completed_total[5m])",
          "legendFormat": "{{device}} reads",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_writes_completed_total[5m])",
          "legendFormat": "{{device}} writes",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Load Average",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 4 },
              { "color": "red", "value": 8 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "node_load1", "legendFormat": "1m", "refId": "A" },
        { "expr": "node_load5", "legendFormat": "5m", "refId": "B" }
      ]
    },
    {
      "title": "Memory Available",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.15 },
              { "color": "green", "value": 0.3 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes", "refId": "A" }
      ]
    },
    {
      "title": "Filesystem Usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.75 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "1 - (node_filesystem_avail_bytes{fstype=~\"ext4|xfs|btrfs\"} / node_filesystem_size_bytes{fstype=~\"ext4|xfs|btrfs\"})",
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Network I/O",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "Bps"
        }
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|br-.*|docker.*\"}[5m])",
          "legendFormat": "{{device}} rx",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|br-.*|docker.*\"}[5m])",
          "legendFormat": "{{device}} tx",
          "refId": "B"
        }
      ]
    },
    {
      "title": "— Per-Container Resources (cAdvisor) —",
      "type": "text",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 36 },
      "options": {
        "mode": "markdown",
        "content": "### Per-Instance Container Resources\nCPU, memory, and disk I/O broken down by container. Filter by hydra-node, hydra-trp, or express-api."
      }
    },
    {
      "title": "Container CPU Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false
          },
          "unit": "short",
          "decimals": 2
        }
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"hydra-.*\"}[5m])",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Container Memory Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false
          },
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"hydra-.*\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Container Memory (RSS vs Cache)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 46 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "container_memory_rss{name=~\"hydra-.*\"}",
          "legendFormat": "{{name}} RSS",
          "refId": "A"
        },
        {
          "expr": "container_memory_cache{name=~\"hydra-.*\"}",
          "legendFormat": "{{name}} cache",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Container Disk I/O (bytes/sec)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 46 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "Bps"
        }
      },
      "targets": [
        {
          "expr": "rate(container_fs_reads_bytes_total{name=~\"hydra-.*\"}[5m])",
          "legendFormat": "{{name}} read",
          "refId": "A"
        },
        {
          "expr": "rate(container_fs_writes_bytes_total{name=~\"hydra-.*\"}[5m])",
          "legendFormat": "{{name}} write",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Container Network I/O (bytes/sec)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 54 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "Bps"
        }
      },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\"hydra-.*\"}[5m])",
          "legendFormat": "{{name}} rx",
          "refId": "A"
        },
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\"hydra-.*\"}[5m])",
          "legendFormat": "{{name}} tx",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["hydra", "cardano", "l2"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
