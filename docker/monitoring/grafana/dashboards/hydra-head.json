{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Confirmed Transactions (rate/min)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "tx/min",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "rate(hydra_head_confirmed_tx[1m]) * 60",
          "legendFormat": "{{network}}/{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Transaction Confirmation Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "ms",
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(hydra_head_tx_confirmation_time_ms_bucket[5m]))",
          "legendFormat": "p50 {{network}}/{{instance}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(hydra_head_tx_confirmation_time_ms_bucket[5m]))",
          "legendFormat": "p95 {{network}}/{{instance}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(hydra_head_tx_confirmation_time_ms_bucket[5m]))",
          "legendFormat": "p99 {{network}}/{{instance}}",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Confirmed vs Requested Transactions",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "total",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "hydra_head_confirmed_tx",
          "legendFormat": "confirmed {{network}}/{{instance}}",
          "refId": "A"
        },
        {
          "expr": "hydra_head_requested_tx",
          "legendFormat": "requested {{network}}/{{instance}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Peer Connections",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "hydra_head_peers_connected",
          "legendFormat": "{{network}}/{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Inputs Processed",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "hydra_head_inputs",
          "legendFormat": "{{network}}/{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requested Transaction Rate (rate/min)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "tx/min",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "rate(hydra_head_requested_tx[1m]) * 60",
          "legendFormat": "{{network}}/{{instance}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["hydra", "cardano", "l2"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Hydra Head Performance",
  "uid": "hydra-head-performance",
  "version": 1
}
