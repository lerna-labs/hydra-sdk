# ──────────────────────────────────────────────────
# Mainnet-Specific Environment Variables
# ──────────────────────────────────────────────────

# The transaction ID containing Hydra Reference Scripts on the network
HYDRA_TX_ID=0571111c9cdbc4880625fb70c88eb2de1e09752a7b5a984644f7be6a0037051f,e0f89d9d24096de8c654302f00d80895c9e28c16ed40a4b2a086ddbeb915cf11,62f2e60c2d2e31e7dee22eea0f6f55903ff862c5c8b3205f48a498920a03a851

# The directory that will hold the configuration files, keys, and Hydra persistence files
SCRIPTS_DIR=../scripts/mainnet

USE_TLS=0

# Your Blockfrost API key for the network you're connecting to
BLOCKFROST_API_KEY=mainnet<your_api_key_here>

HYDRA_NETWORK=1

# The host used for hydra-node HTTP and WS API
API_HOST=0.0.0.0
# The host used by hydra-node to connect to peers
LISTEN_HOST=0.0.0.0
# The host used by Tx3 Hydra TRP
TRP_HOST=0.0.0.0

# The port that Cardano node will use
CARDANO_PORT=3000
# The port that our Express API will be exposed on
EXPRESS_PORT=3001
# The port used for hydra-node HTTP and WS API
API_PORT=4001
# The port used by hydra-node to connect to peers
LISTEN_PORT=5001
# The port used by Tx3 Hydra TRP
TRP_PORT=8165

# The full URL for the Hydra HTTP API
HYDRA_API_URL="http://hydra-node-${NETWORK}-${INSTANCE}:${API_PORT}"

# The full URL for the Hydra WS API
HYDRA_WS_URL="ws://hydra-node-${NETWORK}-${INSTANCE}:${API_PORT}"

# The full URL for the Tx3 Hydra TRP
TRP_URL="http://hydra-trp-${NETWORK}-${INSTANCE}:${TRP_PORT}"